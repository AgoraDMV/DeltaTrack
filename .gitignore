.env
# Private operator/AI notes — threat analysis, exact resource thresholds, etc.
# Never publish: see docs-for-ai/deployment-security-notes.md
docs-for-ai/
.DS_Store
__pycache__/
.pytest_cache/
.coverage
htmlcov/
.venv/
# Git worktrees live inside the repo here; never commit them as gitlinks
.claude/worktrees/
bills/*
!bills/.gitkeep
!bills/large_bills.csv
# Vendored public-domain (17 U.S.C. 105) govinfo sources for the external-validation suite:
# the Senate reported-bill XML each validation jurisdiction checks. Pinning the exact bytes
# keeps the committed validation_*.json fixtures reproducible and lets the suite run in CI.
# The broader (large) bill corpus stays ignored and is fetched on demand.
!bills/118-s-*/
bills/118-s-*/*
!bills/118-s-*/1_reported-in-senate.xml
# Vendored public-domain (17 U.S.C. 105) PDF fixtures for the glyph-size
# heading-segmentation tests (#89), so they gate CI without fetching: an approps
# House bill (PDF+XML, the FEDERAL PROTECTIVE SERVICE / account-detection case and
# the harness oracle) and a non-approps House bill (PDF, the generalization case).
!bills/118-hr-8752/
bills/118-hr-8752/*
!bills/118-hr-8752/1_reported-in-house.pdf
!bills/118-hr-8752/1_reported-in-house.xml
!bills/118-hr-8282/
bills/118-hr-8282/*
!bills/118-hr-8282/1_introduced-in-house.pdf
reports/*
!reports/.gitkeep
plans/
test_data/*
!test_data/validation_*.json
!test_data/pdf/
# Vendored committee-report HTML (public domain) — the external-validation ground-truth source.
!test_data/CRPT-*.htm
# Persistent PDF extraction cache (developer test-loop speedup; see tests/pdf_corpus.py)
test_data/extract_cache/
*.csv
# Vendored GPO render chain (public domain, ~2.2MB incl. binary JPGs) — local reference only.
# Mined into docs/gpo-render-conventions.md; re-fetch from govinfo bulkdata when needed. See DeltaTrack#40.
reference/
